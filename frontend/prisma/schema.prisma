generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ItemStatus {
  OWNED
  LOST
  STOLEN
  DAMAGED
  DESTROYED
}

enum UserRole {
  OWNER
  VIEWER
}

model Catalogue {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  icon        String?
  items       Item[]
  collections Collection[]
  stocktakeSessions StocktakeSession[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Collection {
  id          String           @id @default(cuid())
  name        String
  description String?
  catalogueId String
  catalogue   Catalogue        @relation(fields: [catalogueId], references: [id])
  items       CollectionItem[]
  stocktakeSessions StocktakeSession[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([name, catalogueId])
}

model Item {
  id             String           @id @default(cuid())
  name           String
  description    String?
  barcode        String?
  isbn           String?
  catalogueId    String
  catalogue      Catalogue        @relation(fields: [catalogueId], references: [id])
  collections    CollectionItem[]
  status         ItemStatus       @default(OWNED)
  imageUrl       String?
  manufacturer   String?
  author         String?
  publisher      String?
  year           Int?
  metadata       Json?
  notes          String?
  estimatedValue Decimal?         @db.Decimal(10, 2)
  valueFetchedAt DateTime?
  stocktakeItems StocktakeItem[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model CollectionItem {
  id           String     @id @default(cuid())
  itemId       String
  item         Item       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([itemId, collectionId])
}

model User {
  id                String             @id @default(cuid())
  name              String
  email             String             @unique
  passwordHash      String
  role              UserRole           @default(VIEWER)
  stocktakeSessions StocktakeSession[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model StocktakeSession {
  id          String          @id @default(cuid())
  name        String
  catalogueId String?
  collectionId String?
  createdById String
  catalogue   Catalogue?      @relation(fields: [catalogueId], references: [id])
  collection  Collection?     @relation(fields: [collectionId], references: [id])
  createdBy   User            @relation(fields: [createdById], references: [id], onDelete: Cascade)
  items       StocktakeItem[]
  notes       String?
  startedAt   DateTime        @default(now())
  endedAt     DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model StocktakeItem {
  id         String           @id @default(cuid())
  sessionId  String
  itemId     String?
  label      String
  scanValue  String?
  expected   Boolean          @default(false)
  scannedAt  DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  session    StocktakeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  item       Item?            @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([sessionId, expected])
  @@index([sessionId, scannedAt])
}

model Report {
  id        String   @id @default(cuid())
  name      String
  format    String
  scopeType String
  scopeId   String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
